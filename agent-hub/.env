# Agent Infra API Configuration

# Base URL for the Agent Infra API
# Development: http://localhost:8787
# Production: https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8787

# Master API Key for admin endpoints
# This key grants access to all admin endpoints:
# - POST /v1/admin/chat (unlimited chat)
# - GET /v1/keys (list API keys)
# - POST /v1/keys (create API key)
# - POST /v1/keys/:id/revoke (revoke API key)
# - POST /v1/keys/:id/activate (activate API key)
# - DELETE /v1/keys/:id (delete API key)
# - POST /v1/rag/ingest (ingest documents)
# - GET /v1/rag/jobs/:jobId (check RAG job status)
# - GET /v1/rag/search (search knowledge base)
#
# ⚠️ IMPORTANT: Never commit the actual master key to version control!
# Copy this file to .env and add your real master key there
VITE_MASTER_API_KEY=sk-MLWBX0RK-1DBD07RkEkuSnIs7l53QgKjlk6DpswLLLx8jwSDT74nk3gNoUL54m0IAxzVRPHi8
