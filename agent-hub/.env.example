# Client-side config (safe to expose)
VITE_API_BASE_URL=https://api-agent.naisu.one

# Server-side proxy config (Vercel project env, DO NOT expose to client)
# Required
# API_BASE_URL=https://api-agent.naisu.one
# MASTER_API_KEY=sk-your-master-api-key-here

# Admin login (server-side)
# Option A (quick): plain password
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-this-now

# Option B (recommended): scrypt hash format -> scrypt$<saltHex>$<hashHex>
# ADMIN_PASSWORD_HASH=scrypt$...

# Session
# ADMIN_SESSION_SECRET=use-a-long-random-secret-at-least-16-chars
# ADMIN_SESSION_MAX_AGE_SECONDS=28800
