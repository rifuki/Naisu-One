# ── Strategy ───────────────────────────────────────────────────────────────────
MIN_PROFIT_BPS=50

# ── Solver Network (optional — enables registration + RFQ server) ──────────────
# Without these the solver still runs but won't participate in backend-coordinated auctions
SOLVER_NAME=alpha                          # unique solver name (e.g. alpha / beta / gamma)
SOLVER_BACKEND_URL=http://localhost:3000   # naisu-backend base URL
SOLVER_RFQ_PORT=3001                       # port to receive RFQ calls from backend (unique per instance)
SOLVER_QUOTE_DISCOUNT_BPS=100             # discount off startPrice for user (100 = 1%, 300 = 3%)
SOLVER_ETA_SECONDS=8                       # claimed fill time in seconds
# SOLVER_TUI=false                         # set false for plain logs (recommended when running 3 instances)
