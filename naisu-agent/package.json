{
  "name": "agent-infra-langchain-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "generate-key": "node -e \"console.log('sk-' + require('crypto').randomBytes(32).toString('hex'))\""
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/core": "^1.1.29",
    "@langchain/openai": "^0.5.16",
    "dotenv": "^16.4.5",
    "fastify": "^5.7.4",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "pino-pretty": "^13.1.3",
    "redis": "^4.7.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
