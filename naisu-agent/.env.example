# ============================================
# LLM Provider Configuration
# ============================================

# Choose your LLM provider: openai | kimi | heurist
LLM_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=                    # Optional: custom OpenAI-compatible endpoint

# --- Kimi (Moonshot AI) Configuration ---
KIMI_API_KEY=your_kimi_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1

# --- Heurist LLM Gateway Configuration ---
# Heurist provides decentralized open-source LLMs at low cost
# Get API key from: https://heurist.xyz
# API key format: your_user_id#your_api_key
HEURIST_API_KEY=your_user_id#your_api_key_here
HEURIST_BASE_URL=https://llm-gateway.heurist.xyz

# Default model (provider-specific)
# OpenAI: gpt-4.1-mini, gpt-4, gpt-3.5-turbo
# Kimi: kimi-k2-turbo-preview, kimi-k2-5, kimi-k2
# Heurist: hermes-3-llama3.1-8b, mistralai/mixtral-8x7b-instruct, meta-llama/llama-3-70b-instruct
MODEL=gpt-4.1-mini

# Embeddings model is automatically selected based on LLM_PROVIDER:
# - OpenAI: text-embedding-3-small
# - Kimi: text-embedding-v2
# - Heurist: BAAI/bge-large-en-v1.5

# ============================================
# API Authentication (Optional)
# ============================================

# Enable API key authentication for all endpoints (except /health)
API_KEY_REQUIRED=false

# API key for Bearer token authentication (required when API_KEY_REQUIRED=true)
# Generate a secure key or use: node -e "console.log('sk-' + require('crypto').randomBytes(32).toString('hex'))"
API_KEY=sk-your-secure-api-key-here

# ============================================
# Rate Limiting Configuration
# ============================================

# Enable rate limiting for public endpoints
RATE_LIMIT_ENABLED=true

# Rate limiter backend: json (default) | redis
# - json: Uses local JSON file (good for single instance)
# - redis: Uses Redis (good for multi-instance deployments)
RATE_LIMIT_BACKEND=json

# Default rate limit: requests per time window (default: 10 per hour)
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=3600

# Device ID header name (clients should send unique device ID)
RATE_LIMIT_DEVICE_HEADER=X-Device-ID

# Trust proxy headers for IP detection (set to false if not behind a proxy)
RATE_LIMIT_TRUST_PROXY=true

# Per-endpoint overrides (optional)
# RATE_LIMIT_CHAT_MAX=10
# RATE_LIMIT_CHAT_WINDOW=3600
# RATE_LIMIT_ADMIN_MAX=1000
# RATE_LIMIT_ADMIN_WINDOW=3600

# ============================================
# Server Configuration
# ============================================
PORT=8787
NODE_ENV=development

# ============================================
# OAuth Configuration (Optional)
# ============================================

# Enable OAuth authentication
OAUTH_ENABLED=false

# OAuth provider: kimi | custom
OAUTH_PROVIDER=kimi

# OAuth credentials (required when OAUTH_ENABLED=true)
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_REDIRECT_URI=http://localhost:8787/v1/oauth/callback

# Custom OAuth endpoints (only needed if OAUTH_PROVIDER=custom)
OAUTH_AUTH_URL=https://kimi.com/oauth/authorize
OAUTH_TOKEN_URL=https://kimi.com/oauth/token
OAUTH_USERINFO_URL=https://kimi.com/oauth/userinfo

# ============================================
# Feature Flags
# ============================================
TOOL_POLICY_MODE=safe_only          # safe_only | allow_all
MEMORY_BACKEND=local                # local | letta | redis
SESSION_BACKEND=local               # local | redis
RAG_BACKEND=none                    # none | llamaindex

# ============================================
# Optional Adapter Configs
# ============================================

# Letta Memory Adapter
LETTA_BASE_URL=
LETTA_API_KEY=

# LlamaIndex RAG Adapter
LLAMAINDEX_BASE_URL=
LLAMAINDEX_API_KEY=

# Redis (for memory/session backends)
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=agentinfra
