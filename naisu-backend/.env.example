# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (Optional - only needed if you want to persist data)
# DATABASE_URL=postgresql://username:password@localhost:5432/naisu_backend

# CORS (comma-separated list, use * only for local dev)
CORS_ORIGIN=http://localhost:5173,http://localhost:8080,https://naisu1-beta.vercel.app,https://naisu.one,https://www.naisu.one

# Logging
LOG_LEVEL=debug

# EVM - Base Sepolia (Testnet)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532

# EVM - Base Mainnet (Production)
BASE_MAINNET_RPC=https://mainnet.base.org
BASE_MAINNET_CHAIN_ID=8453
EVM_NETWORK=base-sepolia

# EVM Admin (for write operations - optional)
# EVM_ADMIN_PRIVATE_KEY=0x...

# Uniswap V4 contracts (selected network)
NAISU_SWAP_CONTRACT=0xfaBD3bdeecf7f858d6cef1c137694e19Ac7187f6
NAISU_REWARDS_CONTRACT=0xD24463BBde91Df1937F4CFC4F627fFc76728b8A6
POOL_MANAGER=0x05E73354cFDd6745C338b50BcFDfA3Aa6fA03408

# EVM Fallback RPC (optional)
# EVM_FALLBACK_RPC_URL=

# Feature Flags
ENABLE_UNISWAP_V4=true

# Redis (optional, for caching)
# REDIS_URL=

# Security
API_KEY_HEADER=x-api-key

# Sui (Testnet) - for Cetus CLMM and Intent Bridge
SUI_PRIVATE_KEY=
# Format: hex private key (64 chars) or bech32 (suiprivkey...)
SUI_RPC_URL=https://fullnode.testnet.sui.io

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Intent Bridge — Solana (Anchor program, devnet)
SOLANA_INTENT_PROGRAM_ID=Cp6HRKWXgeEycareLXGttNj8dTNfRiFB4Y4UtDuq5EcN

# Intent Bridge — Sui (Testnet)
SUI_PACKAGE_ID=0x920f52f8b6734e5333330d50b8b6925d38b39c6d0498dd0053b76e889365cecb
SUI_BRIDGE_STATE_ID=0x7aac5f895e7071fc33a65fe4325365bb287c64d229d1af1d03e613c8153b3703

# Intent Bridge — EVM Base Sepolia (Testnet)
BASE_SEPOLIA_INTENT_CONTRACT=0xFCDE966395c39ED59656BC0fd3a310747Eb68740
BASE_SEPOLIA_WS_URL=wss://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY  # optional, enables real-time WS indexer
